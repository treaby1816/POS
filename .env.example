# Treabyn POS & Accounting - Environment Variables

# Desktop Client (.env should be placed in apps/desktop/.env)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Edge Functions (Managed via Supabase CLI secrets)
# These should be set using: supabase secrets set NAME=VALUE
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
LICENSE_SECRET=your-secure-random-hmac-secret-key-min-32-chars
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
RESEND_API_KEY=re_your_resend_api_key
